{
  "general": {
    "vimMode": false,
    "preferredEditor": "vim",
    "gitCoAuthor": false
  },
  "ui": {
    "showLineNumbers": true,
    "enableUserFeedback": false
  },
  "webSearch": {
    "provider": [
      {
        "type": "dashscope"
      },
      {
        "type": "tavily",
        "apiKey": "$TAVILY_API_KEY"
      }
    ],
    "default": "dashscope"
  },
  "tools": {
    "approvalMode": "default",
    "allowed": [
      "web_search",
      "web_fetch",
      "read_file",
      "glob",
      "grep_search",
      "read_many_files",
      "list_directory",
      "save_memory",
      "todo_write",
      "task",
      "run_shell_command(find)",
      "run_shell_command(head)",
      "run_shell_command(tail)",
      "run_shell_command(ls)",
      "run_shell_command(wc)",
      "run_shell_command(pwd)",
      "run_shell_command(date)",
      "run_shell_command(uname)",
      "run_shell_command(which)",
      "run_shell_command(git status)",
      "run_shell_command(git diff *)",
      "run_shell_command(git log *)",
      "run_shell_command(git branch *)",
      "run_shell_command(git show *)",
      "run_shell_command(git stash *)",
      "run_shell_command(git remote *)",
      "run_shell_command(git config --list)",
      "run_shell_command(git add *)",
      "run_shell_command(git commit *)",
      "run_shell_command(curl)",
      "run_shell_command(mkdir)",
      "run_shell_command(touch)",
      "run_shell_command(du)",
      "run_shell_command(df)",
      "run_shell_command(ps)"
    ]
  },
  "context": {
    "fileName": [
      "QWEN.md",
      "AI.md"
    ]
  },
  "$version": 3,
  "security": {
    "auth": {
      "selectedType": "qwen-oauth"
    }
  },
  "modelProviders": {
    "openai": [
      {
        "id": "local-27b",
        "name": "Qwen3.5 27B (Local)",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8080/v1"
      },
      {
        "id": "llama-arch",
        "name": "LLama Architecture",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8081/v1"
      },
      {
        "id": "llama-review",
        "name": "LLama Code Review",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8082/v1"
      },
      {
        "id": "llama-debug",
        "name": "LLama Debugging",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8083/v1"
      },
      {
        "id": "llama-security",
        "name": "LLama Security Audit",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8084/v1"
      },
      {
        "id": "llama-explorer",
        "name": "LLama Code Exploration",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8085/v1"
      },
      {
        "id": "llama-builder",
        "name": "LLama Code Builder",
        "envKey": "LOCAL_API_KEY",
        "baseUrl": "http://192.168.0.101:8086/v1"
      }
    ]
  },
  "model": {
    "name": "coder-model"
  }
}